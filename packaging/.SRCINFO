pkgbase = archcanary
	pkgdesc = Layered security detection stack for Arch Linux — malicious AUR packages, systemd/eBPF persistence, npm/bun cache poisoning, kernel module tampering
	pkgver = 0.1.17
	pkgrel = 1
	url = https://github.com/musqz/archcanary
